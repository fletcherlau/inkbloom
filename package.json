  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "vitest": "node --input-type=module -e \"import { spawnSync } from 'node:child_process'; const args = process.argv.slice(1).filter((arg) => arg !== '--runInBand'); const result = spawnSync('vitest', args, { stdio: 'inherit' }); process.exit(result.status ?? 1);\"",
